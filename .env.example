# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Server
PORT=3000
HOST=0.0.0.0

# Storage
IDOL_FRAME_DATA_DIR=./data

# Logging: debug | info | warn | error
LOG_LEVEL=info

# Environment: development | production | test
NODE_ENV=development

# API Authentication (optional — if not set, API runs unauthenticated)
IDOL_FRAME_API_KEY=

# CORS origin (default: * allows all; set specific origin in production)
CORS_ORIGIN=*

# --- Wallet Providers (optional) ---

# Coinbase AgentKit — smart wallets on Base L2
# Get credentials at: https://portal.cdp.coinbase.com
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=
# CDP_WALLET_SECRET=
# COINBASE_NETWORK_ID=base-mainnet
# COINBASE_PAYMASTER_URL=

# Stripe Agent Toolkit — Web2 payments via MCP
# Get credentials at: https://dashboard.stripe.com → Developers → API Keys
# Use restricted key (rk_*) for production
# STRIPE_API_KEY=
